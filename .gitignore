# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
.venv/
env/

# Data — recordings & detection results (never commit)
data/
logs/

# Models — ignore heavy weights, keep NCNN (optimised for Pi)
models/*.pt
models/*.onnx
models/*.engine
models/*.torchscript
# NCNN model dirs are small and deploy-ready — track them
!models/*_ncnn_model/

# Local config (may contain device-specific paths)
config.yaml

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# PlatformIO (firmware build artefacts)
firmware/
